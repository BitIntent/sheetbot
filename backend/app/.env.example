# 环境配置示例文件
# 复制此文件为 .env 并填写实际配置

# ==============================================
# 应用基础配置
# ==============================================
DEBUG=false
PORT=8080

# ==============================================
# MySQL 数据库配置
# ==============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sheetbot_db
DB_USER=sheetbot_user
DB_PASS=your-db-password

# ==============================================
# JWT 认证配置
# ==============================================
# 生产环境必须修改为随机的强密钥！
# 可以使用：openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==============================================
# AI Agent 配置
# ==============================================
ANTHROPIC_API_KEY=your-anthropic-api-key
# 兼容项：若网关只提供 auth token，可仅配置该项（系统会自动映射到 API_KEY）
# ANTHROPIC_AUTH_TOKEN=your-anthropic-auth-token
# 可选：显式固定 Agent 模型（优先级高于 ANTHROPIC_DEFAULT_*_MODEL）
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# 可选：当未显式指定 model 时，作为默认 Sonnet 档
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # 可选，自定义 API 端点

# ==============================================
# Agent 生命周期配置
# ==============================================
AGENT_IDLE_TTL_SEC=60
AGENT_CLEANUP_INTERVAL_SEC=30
AGENT_PER_REQUEST_CLOSE=true

# ==============================================
# 文件存储配置
# ==============================================
UPLOAD_DIR=uploads

# ==============================================
# 前端大文件自动分流阈值（可选，仅首屏兜底；正式值：platform_settings 表）
# ==============================================
VITE_AUTO_ANALYZE_MAX_FILE_MB=20
VITE_AUTO_ANALYZE_MAX_ROWS=20000

# ==============================================
# 认证邮件 / 忘记密码配置
# ==============================================
# 企业邮箱 SMTP（SSL）
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=your-smtp-user@example.com
SMTP_PASSWORD=replace-with-your-smtp-password
SMTP_FROM_NAME=SheetBot Support
SMTP_TIMEOUT_SECONDS=15

# SheetBot 公网访问地址（用于拼接密码重置链接）
SHEETBOT_PUBLIC_BASE_URL=http://localhost

# 忘记密码重置链接有效期（分钟）
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# 官网商务咨询通知收件人（多个邮箱用逗号分隔）
BUSINESS_INQUIRY_NOTIFY_EMAILS=
